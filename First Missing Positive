class Solution:
    def ladderLength(self, beginWord: str, endWord: str, wordList: List[str]) -> int:
        q  = deque()
        wordset = set(wordList)
        q.append([beginWord])
        wordset.discard(beginWord)
        mintrans = 1

        while q:
            currlist = q.popleft()
            a = []
            for ele in currlist:
                if ele == endWord:
                    return mintrans
                l = list(ele)
                for i in range(len(l)):
                    ch = l[i]
                    for c in range(97,123):
                        l[i] = chr(c)
                        s = "".join(l)
                        if s in wordset:
                            a.append(s)
                            wordset.remove(s)
                    l[i]= ch
            if a!=[]:
                print(a)
                q.append(a)
                mintrans+=1
        return 0
