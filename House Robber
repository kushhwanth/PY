
class Solution:
    def rob(self, nums: List[int]) -> int:
        if not nums:
            return 0
        n = len(nums)
        if n == 1:
            return nums[0]
        p1 , p2 = nums[0],0
        for i in range(1,n):
            curr = max(p1,p2+nums[i])
            p2,p1=p1,curr
        return p1


