class Solution:
    def canJump(self, a: List[int]) -> bool:
        if len(a) == 1:
            return True

        reachable = [False] * len(a)
        reachable[0] = True   

        for i in range(len(a)):
            if not reachable[i]:   
                continue
            for j in range(1, a[i] + 1):
                if i + j >= len(a) - 1:
                    return True
                reachable[i + j] = True

        return False

